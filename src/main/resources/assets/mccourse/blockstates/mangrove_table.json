{
  "multipart": [
    {
      "apply": {
        "model": "mccourse:block/mangrove_table_top"
      }
    },
    {
      "when": {
        "north": "false",
        "west": "false"
      },
      "apply": {
        "model": "mccourse:block/mangrove_table_leg"
      }
    },
    {
      "when": {
        "north": "false",
        "east": "false"
      },
      "apply": {
        "model": "mccourse:block/mangrove_table_leg",
        "y": 90
      }
    },
    {
      "when": {
        "south": "false",
        "east": "false"
      },
      "apply": {
        "model": "mccourse:block/mangrove_table_leg",
        "y": 180
      }
    },
    {
      "when": {
        "south": "false",
        "west": "false"
      },
      "apply": {
        "model": "mccourse:block/mangrove_table_leg",
        "y": 270
      }
    }
  ]
}